{"id": "pg_l2_001", "level": "L2", "query": "Give me a breakdown of how many flights exist for each possible flight status (e.g. Scheduled, Departed, Arrived, Cancelled) in the flights table.", "function": "execute_query", "expected_params": {"sql": "SELECT status, COUNT(*) as count FROM bookings.flights GROUP BY status ORDER BY count DESC"}, "expected_outcome": {"result": [{"status": "Arrived", "count": 16707}, {"status": "Scheduled", "count": 15383}, {"status": "On Time", "count": 518}, {"status": "Cancelled", "count": 414}, {"status": "Departed", "count": 58}, {"status": "Delayed", "count": 41}], "row_count": 6}, "optimal_steps": 1}
{"id": "pg_l2_002", "level": "L2", "query": "Which 5 airports have the highest number of departing flights? Return the airport code and the flight count.", "function": "execute_query", "expected_params": {"sql": "SELECT departure_airport, COUNT(*) as flight_count FROM bookings.flights GROUP BY departure_airport ORDER BY flight_count DESC LIMIT 5"}, "expected_outcome": {"row_count": 5}, "optimal_steps": 1}
{"id": "pg_l2_003", "level": "L2", "query": "Calculate the average ticket amount for each fare condition (Economy, Comfort, Business) from the ticket_flights table, sorted from most to least expensive.", "function": "execute_query", "expected_params": {"sql": "SELECT fare_conditions, AVG(amount) as avg_amount FROM bookings.ticket_flights GROUP BY fare_conditions ORDER BY avg_amount DESC"}, "expected_outcome": {"row_count": 3}, "optimal_steps": 1}
{"id": "pg_l2_004", "level": "L2", "query": "For every aircraft code in the seats table, count the total number of seats. Return all aircraft codes sorted by seat count descending.", "function": "execute_query", "expected_params": {"sql": "SELECT aircraft_code, COUNT(*) as seat_count FROM bookings.seats GROUP BY aircraft_code ORDER BY seat_count DESC"}, "expected_outcome": {"row_count": 9}, "optimal_steps": 1}
{"id": "pg_l2_005", "level": "L2", "query": "What is the sum of total_amount across all rows in the bookings table?", "function": "execute_query", "expected_params": {"sql": "SELECT SUM(total_amount) as total_revenue FROM bookings.bookings"}, "expected_outcome": {"row_count": 1}, "optimal_steps": 1}
{"id": "pg_l2_006", "level": "L2", "query": "Count the number of ticket_flights records for each fare_conditions value, sorted from highest to lowest count.", "function": "execute_query", "expected_params": {"sql": "SELECT fare_conditions, COUNT(*) as passenger_count FROM bookings.ticket_flights GROUP BY fare_conditions ORDER BY passenger_count DESC"}, "expected_outcome": {"row_count": 3}, "optimal_steps": 1}
