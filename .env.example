# Copy this file to .env and fill in your Supabase credentials.
# Get these from: https://supabase.com → your project → Settings → API

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# PostgreSQL connection string for the Postgrespro demo database
# Download demo-small-en.zip from https://postgrespro.com/community/demodb
# Then: createdb demo && pg_restore -d demo demo-small-en.zip
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/demo
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key